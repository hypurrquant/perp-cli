{
  "name": "perp-cli",
  "version": "0.3.0",
  "description": "Multi-DEX Perpetual Futures CLI - Pacifica, Hyperliquid, Lighter",
  "bin": {
    "perp": "./dist/index.js",
    "perp-mcp": "./dist/mcp-server.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --exclude '**/integration/**'",
    "test:integration": "vitest run --include '**/integration/**'",
    "test:all": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "pacifica",
    "hyperliquid",
    "lighter",
    "solana",
    "perps",
    "dex",
    "cli",
    "trading",
    "funding-rate",
    "arbitrage"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@msgpack/msgpack": "^3.1.3",
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0",
    "ethers": "^6.13.2",
    "hyperliquid": "^1.7.7",
    "lighter-sdk": "^0.0.17",
    "tweetnacl": "^1.0.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
